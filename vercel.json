{
  "version": 2,
  "builds": [
    { "src": "*.html",          "use": "@vercel/static" },
    { "src": "assets/**",       "use": "@vercel/static" },
    { "src": "api/leads.js",    "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/",           "dest": "/index.html" },
    { "src": "/sprint",     "dest": "/sprint.html" },
    { "src": "/calculator", "dest": "/calculator.html" },
    { "src": "/thank-you",  "dest": "/thank-you.html" },
    { "src": "/privacy",    "dest": "/privacy.html" },
    { "src": "/terms",      "dest": "/terms.html" },
    { "src": "/ref/(.*)",   "dest": "/ref-redirect.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)",       "dest": "/404.html", "status": 404 }
  ]
}
